# Anthropic API key —— 仅 --live 模式需要；replay_demo 默认用 MockGateway，无需 key
ANTHROPIC_API_KEY=sk-ant-...

# ---- 模型选择：写成 provider_alias::model（别名与模型名解耦，见 gateway/router.py）----
# 内置别名（配了对应标准 key 即可用）：
#   anthropic::claude-opus-4-8   openai::gpt-4o   gemini::gemini-2.0-flash
# 不带 # 的裸模型名仍按前缀推断路由（向后兼容），但推荐显式写别名。

# 其他 provider 的标准 key：
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1          # 让内置 openai 别名指向兼容端点时改这里
# GEMINI_API_KEY=...                                  # 或 GOOGLE_API_KEY

# 额外命名 provider —— 两种写法，任选：
#
# 写法 A（推荐，声明式）：写一个 providers.json（见 examples/providers.example.json），
#   每个 provider 一个块：{ "alias", "type", "provider_url", "api_key_env" }。
#   放在项目根会被自动加载；或用 AICG_PROVIDERS_FILE 指定路径。密钥仍留在下面这些 *_env 里。
# AICG_PROVIDERS_FILE=providers.json
# DEEPSEEK_API_KEY=sk-...
# GROQ_API_KEY=gsk-...
#
# 写法 B（摊平进 env，无需额外文件）：
# AICG_PROVIDERS=deepseek,groq
# AICG_PROVIDER_DEEPSEEK_KIND=openai                  # openai | anthropic | gemini（默认 openai）
# AICG_PROVIDER_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# AICG_PROVIDER_DEEPSEEK_API_KEY=sk-...               # 或 AICG_PROVIDER_DEEPSEEK_API_KEY_ENV=DEEPSEEK_KEY
#
# 两种写法都让你之后在角色卡 / 调度模型里写 deepseek::deepseek-chat

# 可选：覆盖各层默认模型（推荐用别名::模型 形式）
# AICG_MODEL_OPUS=anthropic::claude-opus-4-8
# AICG_MODEL_SONNET=anthropic::claude-sonnet-5
# AICG_MODEL_HAIKU=anthropic::claude-haiku-4-5
# AICG_MODEL_CONDUCTOR=anthropic::claude-haiku-4-5     # 调度（conductor）用便宜模型（旧名 AICG_MODEL_DIRECTOR 仍兼容）
# AICG_MODEL_USHER=anthropic::claude-haiku-4-5         # M2 用户输入台口分流用便宜模型
# AICG_MODEL_COMPACTION=anthropic::claude-haiku-4-5    # 压缩用便宜模型
# AICG_MODEL_STORYTELLER=anthropic::claude-opus-4-8    # M2 会话级编导（重模型，只在边界跑）

# 可选：主循环节奏与 compaction 阈值
# AICG_TURN_INTERVAL_S=1.5
# AICG_IDLE_POLL_S=2.0
# AICG_MAX_HISTORY=60
# AICG_KEEP_LAST=20
# AICG_SQLITE_PATH=aichatgroup.sqlite
# AICG_PRESET_PATH=examples/room.example.json

# ---- M1 Telegram 落地（scripts/run_telegram.py 需要）----
# 观察者 bot（务必在 BotFather 关掉 privacy mode）+ 群 chat_id
TG_TOKEN_OBSERVER=123456:观察者bot-token
TG_CHAT_ID=-1001234567890
# 每个角色一个 bot token（与预设 JSON 里的 bot_token_env 对应，按槽位编号、不绑角色名）
TG_TOKEN_CHAR_1=123456:角色1bot-token
TG_TOKEN_CHAR_2=123456:角色2bot-token
TG_TOKEN_CHAR_3=123456:角色3bot-token
